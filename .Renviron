# Google Sheets - ID da planilha-base (entre /d/ e /edit na URL)
PUCJR_SHEET_ID= 1mMTK8k1wxd3KGfQ-_wBA0zSmySj1OMpDwKNzldE3WUk

# Google Drive - ID da pasta de comprovantes
PUCJR_DRIVE_FOLDER_ID= 1MZkrFglSKA8RXUUYKzDbBG1tyLtDe-Df

# Caminho da chave JSON do service account.
# Deixe VAZIO para usar autenticação SEM CHAVE (keyless): Application Default
# Credentials -> metadados do Google Cloud (Cloud Run/GCE) -> Federação de
# Identidade. Veja a seção 3.7 do guia.
PUCJR_SA_JSON=service-account.json

